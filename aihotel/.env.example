# Скопировать этот файл в .env и заполнить значения

ROUTERAI_API_KEY=sk-...          # RouterAI (routerai.ru) — DeepSeek V4 Pro для Агента 2
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
GROQ_API_KEY=gsk_...            # Groq — используется в Агенте 1 (аналитика)

# СОДЕРЖИМОЕ credentials.json одной строкой (не путь к файлу, а сам JSON)
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}

FINANCE_SHEET_ID=1aBcD...   # ID из URL таблицы (между /d/ и /edit)
STRATEGY_SHEET_ID=1xYz...

# TravelLine API (для автосбора данных)
TL_CLIENT_ID=...
TL_CLIENT_SECRET=...
TL_PROPERTY_ID=...
