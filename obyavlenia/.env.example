# ============================================================
# Скопируй этот файл в .env и заполни своими данными:
#   cp .env.example .env
# ============================================================

# ─── Макс (ICQ New) Bot — уведомления ───────────────────────────────────────
#
# Шаг 1. Открой приложение Макс
# Шаг 2. Найди бота @metabot и напиши ему /newbot
# Шаг 3. Придумай имя и юзернейм бота
# Шаг 4. Скопируй токен сюда:
ICQ_BOT_TOKEN=001.1234567890.abcdef:1234567

# Шаг 5. Узнай свой ICQ_CHAT_ID:
#   Вариант А — это просто твой номер телефона в формате +79991234567
#   Вариант Б — напиши своему боту /start, потом проверь:
#     https://api.icq.net/bot/v1/events/get?token=ТВОЙ_ТОКЕН&pollTime=5
#   В ответе найди поле "from" → "userId"
ICQ_CHAT_ID=+79991234567

# ─── Google Sheets ──────────────────────────────────────────────────────────
# Инструкция в README.md — раздел «Шаг 3»
GOOGLE_CREDENTIALS_FILE=credentials.json
# ID из адреса таблицы: https://docs.google.com/spreadsheets/d/ВОТ_ЭТОТ_ID/edit
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ─── Telegram MTProto (только для парсинга ТГ-каналов, не для уведомлений) ──
# Нужно только если добавишь Telegram-каналы в telegram_sources.json
# Регистрация: https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Расписание ─────────────────────────────────────────────────────────────
# Время ежедневного запуска (МСК)
RUN_HOUR=9
RUN_MINUTE=0
